<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!-- 
        Add suppressions for known vulnerabilities that are false positives
        or that you cannot fix right now.
    -->
    
    <!-- Example: Suppress a specific CVE -->
    <!--
    <suppress>
        <cve>CVE-2021-12345</cve>
        <packageName>com.example:some-library</packageName>
        <vulnerabilityName>Description of the vulnerability</vulnerabilityName>
        <justification>Reason why this is suppressed</justification>
    </suppress>
    -->
    
    <!-- Suppress vulnerabilities in test dependencies -->
    <suppress>
        <packageName>org.testcontainers:*</packageName>
        <vulnerabilityName>Vulnerability in testcontainers</vulnerabilityName>
        <justification>Test dependencies are not included in production builds</justification>
        <scope>compile</scope>
    </suppress>
    
    <!-- Suppress vulnerabilities in development tools -->
    <suppress>
        <packageName>org.projectlombok:lombok</packageName>
        <cve>CVE-2024-52940</cve>
        <justification>Lombok is an annotation processor, not runtime dependency</justification>
    </suppress>

    <!-- Suppress springdoc vulnerabilities that are not applicable -->
    <suppress>
        <packageName>org.springdoc:springdoc-openapi-starter-webmvc-ui</packageName>
        <cve>CVE-2023-34054</cve>
        <justification>SpringDoc is not vulnerable in this configuration</justification>
    </suppress>
</suppressions>

